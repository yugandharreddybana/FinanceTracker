# ============================================================
# FinanceTracker Server — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Server
PORT=4000
NODE_ENV=development

# Security — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_min_32_chars

# Java / Spring Boot backend (WebAuthn passkey proxy)
JAVA_BACKEND_URL=http://localhost:8081

# AI — NVIDIA NIM API key (https://build.nvidia.com)
NVIDIA_API_KEY=your_nvidia_api_key_here

# AI — Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Redis (optional — OTP store falls back to in-memory in dev if not set)
# REDIS_URL=redis://localhost:6379

# Cookie domain (optional — set for production subdomain sharing)
# COOKIE_DOMAIN=yourdomain.com

# Email provider (optional — needed for OTP delivery in production)
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# EMAIL_FROM=noreply@yourdomain.com
