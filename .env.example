# ============================================================
# FRONTEND (Vite) — deployed on Vercel
# ============================================================
# URL of the Node.js middleware server
VITE_MIDDLEWARE_URL=http://localhost:4000

# DO NOT set VITE_API_URL in frontend — frontend never talks to Spring Boot directly


# ============================================================
# NODE MIDDLEWARE (server/) — deployed on Railway
# ============================================================
PORT=4000
JWT_SECRET=your-64-char-random-secret-here
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
GEMINI_API_KEY=your-gemini-api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# Spring Boot backend URL (used by middleware only, NOT by frontend)
VITE_API_URL=http://localhost:8080


# ============================================================
# SPRING BOOT BACKEND (backend/) — deployed on Railway
# ============================================================
DB_URL=jdbc:postgresql://your-host:5432/your-db
DB_USERNAME=postgres.your-ref
DB_PASSWORD=your-password
DDL_AUTO=validate

# Only allow Node middleware origin, NOT the frontend
ALLOWED_ORIGINS=http://localhost:4000
