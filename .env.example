# ── Node / Express Server ───────────────────────────────────────────────────
# Port the Express server listens on (default: 3000)
PORT=3000

# JWT signing secret – generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-hex

# Comma-separated list of allowed CORS origins (no trailing slash)
ALLOWED_ORIGINS=https://your-frontend-domain.com

# ── Gemini AI ────────────────────────────────────────────────────────────────
# Required for all AI features (insights, chat, forecast, tax suggestions)
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Alpha Vantage (investment prices) ───────────────────────────────────────
# Get your free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# Base URL of the Spring Boot backend (no trailing slash)
# Development:  http://localhost:8080
# Production:   https://your-backend-api.com
VITE_API_URL=http://localhost:8080

# ── Spring Boot Backend ──────────────────────────────────────────────────────
# Full JDBC connection URL for Supabase PostgreSQL (Transaction Mode pooler, port 6543)
DB_URL=jdbc:postgresql://aws-1-eu-west-1.pooler.supabase.com:6543/postgres?currentSchema=finance_app&sslmode=require&prepareThreshold=0

# Supabase project username (found in Supabase Dashboard → Settings → Database)
DB_USERNAME=postgres.your-project-ref

# Supabase database password
DB_PASSWORD=your-database-password

# Hibernate DDL mode: use "validate" in production, "update" only in development
DDL_AUTO=validate

# Comma-separated allowed origins for the Spring Boot CORS config (should match ALLOWED_ORIGINS above)
ALLOWED_ORIGINS=https://your-frontend-domain.com
