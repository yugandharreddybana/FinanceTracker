# ============================================================
# FRONTEND (Vite) — deployed on Vercel
# ============================================================
# URL of the Node.js middleware server
VITE_MIDDLEWARE_URL=http://localhost:4000

# DO NOT set VITE_API_URL in frontend — frontend never talks to Spring Boot directly


# ============================================================
# NODE MIDDLEWARE (server/) — deployed on Railway
# ============================================================
PORT=4000
JWT_SECRET=your-64-char-random-secret-here
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
GEMINI_API_KEY=your_gemini_api_key_here
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# Cookie security — used to scope and sign auth cookies
# COOKIE_SECRET is optional (for signed cookies if added in future)
COOKIE_SECRET=your-random-cookie-secret-here
# COOKIE_DOMAIN restricts the cookie to a specific domain in production
# Leave blank for localhost development
COOKIE_DOMAIN=

# Spring Boot backend URL (used by middleware only, NOT by frontend)
JAVA_BACKEND_URL=http://localhost:8080


# Backend Database Credentials
# Adding prepareThreshold=0 for Supabase Transaction Pooler compatibility
DB_URL="jdbc:postgresql://aws-1-eu-west-1.pooler.supabase.com:6543/postgres?prepareThreshold=0"
DB_USERNAME="postgres.gppcofxrfuxnmgvlpend"
DB_PASSWORD="ItzMeYugi@0809"
DDL_AUTO="update"


# Only allow Node middleware origin, NOT the frontend
ALLOWED_ORIGINS='http://localhost:4000'
