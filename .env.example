# ============================================================
# FRONTEND (Vite) — deployed on Vercel
# ============================================================
# URL of the Node.js middleware/server (Railway)
VITE_MIDDLEWARE_URL=http://localhost:4000

# DO NOT set VITE_API_URL — frontend never calls Spring Boot directly


# ============================================================
# NODE MIDDLEWARE (server/) — deployed on Railway
# ============================================================
PORT=4000

# Required: generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-char-random-secret-here

# NVIDIA NIM API key — get free at https://build.nvidia.com
# Model used: meta/llama-3.3-70b-instruct
NVIDIA_API_KEY=nvapi-your-nvidia-api-key-here

# Alpha Vantage for live stock prices (optional — mock data used if not set)
# Free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# Railway PostgreSQL (add PostgreSQL addon on Railway — DATABASE_URL auto-injected)
# If not set, user accounts fall back to local JSON file (NOT suitable for production)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Your deployed Vercel frontend URL (comma-separated for multiple)
FRONTEND_URL=https://your-app.vercel.app

# Spring Boot backend URL (used by middleware only, never exposed to frontend)
JAVA_BACKEND_URL=http://localhost:8080

# Cookie domain — leave blank for localhost, set to your Railway domain in production
COOKIE_DOMAIN=


# ============================================================
# JAVA SPRING BOOT BACKEND (backend/) — deployed on Railway
# ============================================================
# Supabase PostgreSQL connection string
# Format: jdbc:postgresql://host:port/dbname?prepareThreshold=0
DB_URL=jdbc:postgresql://your-supabase-host:6543/postgres?prepareThreshold=0
DB_USERNAME=postgres.your-project-ref
DB_PASSWORD=your-supabase-db-password

# Hibernate DDL: use "update" for first deploy, "validate" once schema is stable
DDL_AUTO=update

# CORS — only allow the Node middleware (NOT the frontend directly)
ALLOWED_ORIGINS=http://localhost:4000
